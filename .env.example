# Shipal MCP app — local env. Copy to .env and fill in.
# .env is gitignored (see .gitignore).

# Required: 17Track API key. Server refuses to boot without this.
SEVENTEEN_TRACK_API_KEY=

# Optional analytics. Leave SHIPAL_ANALYTICS_KEY blank locally to disable
# (track() becomes a no-op and logs a single warning at startup).
SHIPAL_ANALYTICS_ENDPOINT=https://yavio.ai/shipal/events
SHIPAL_ANALYTICS_KEY=
